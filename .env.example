# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Username for the application database user.
POSTGRES_USER=gdzie-kupic

# Password for the application database user. Change this before first run.
POSTGRES_PASSWORD=changeme

# Name of the application database.
POSTGRES_DB=gdziekupic

# ─── MinIO (S3-compatible object storage) ─────────────────────────────────────
# Root (admin) username for the MinIO instance.
MINIO_ROOT_USER=minioadmin

# Root password for the MinIO instance. Change this before first run.
MINIO_ROOT_PASSWORD=changeme

# S3 bucket used for chat image attachments.
MINIO_BUCKET_NAME=attachments

# ─── Seq (structured logging) ─────────────────────────────────────────────────
# Optional API key for ingesting logs into Seq.
# Leave empty to accept all logs without authentication (development default).
SEQ_API_KEY=

# Admin password set on first startup. Required when authentication is enabled.
SEQ_FIRSTRUN_ADMINPASSWORD=changeme

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret used to sign JWT access tokens. Must be at least 32 characters.
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-chars

# Lifetime of JWT access tokens in days.
JWT_EXPIRY_DAYS=7

# ─── Admin seed account ───────────────────────────────────────────────────────
# Credentials for the initial Admin account created on first startup.
ADMIN_EMAIL=admin@gdziekupic.local
ADMIN_PASSWORD=Admin123!

# ─── Location Service ─────────────────────────────────────────────────────────
# Google Maps Geocoding API key used by gdzie-kupic-location-service.
# https://developers.google.com/maps/documentation/geocoding/get-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── ASP.NET Core ─────────────────────────────────────────────────────────────
# Runtime environment for both .NET services.
ASPNETCORE_ENVIRONMENT=Development
